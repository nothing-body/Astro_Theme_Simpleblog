---
// Hero 版面，接受 title 和 optional heroImage
interface Props {
  title: string;
  heroImage?: string;
}
const { title, heroImage } = Astro.props;
---

<style lang="css">
  .hero {
    position: relative;
    height: 260px;
    /* 若有圖片則使用背景，否則使用漸層底色 */
    background: var(--hero-bg, linear-gradient(135deg, #4e54c8, #8f94fb));
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem 2rem;
    color: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.6));
  }
  .hero h1 {
    position: relative;
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    z-index: 1;
    animation: fadeInUp 0.6s ease-out;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

{
  heroImage ? (
    <section class="hero" style={`background-image: url('${encodeURI(heroImage)}')`}>
      <h1>{title}</h1>
    </section>
  ) : (
    <section class="hero">
      <h1>{title}</h1>
    </section>
  )
}
