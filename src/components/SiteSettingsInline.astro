---
import { useTranslations } from '../i18n/utils';

export interface Props {
  lang: 'zh-tw' | 'en' | 'zh-cn';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="site-settings-inline">
  <label class="site-settings-inline-row">
    <input type="checkbox" id="pref-inline-tz" />
    <span>{t('cookie.rememberTimezone')}</span>
  </label>
  <label class="site-settings-inline-row">
    <input type="checkbox" id="pref-inline-stats" />
    <span>{t('cookie.enableAnalytics')}</span>
  </label>
  <p class="site-settings-inline-hint">{t('cookie.inlineHint')}</p>
  <button type="button" id="site-settings-inline-save" class="btn-primary site-settings-inline-save">
    {t('cookie.save')}
  </button>
</div>

<script is:inline src="/scripts/bb-settings-inline.js" defer></script>

<style is:global>
  .site-settings-inline {
    border: 1.5px solid var(--border-color);
    padding: 1.5rem;
    border-radius: 12px;
    background: rgba(245, 240, 232, 0.5);
    margin: 1rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .site-settings-inline-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .site-settings-inline-row input[type='checkbox'] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--primary-red);
    flex-shrink: 0;
  }

  .site-settings-inline-hint {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
  }

  .site-settings-inline-save {
    margin-top: 0.25rem;
    align-self: flex-start;
  }
</style>
