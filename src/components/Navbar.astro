---
import {
  getDynamicCategoryMapping,
  getLangFromUrl,
  getTargetLangPath,
  useTranslatedPath,
  useTranslations,
} from '../i18n/utils';
import { languages } from '../i18n/ui';
import { SITE_NAME } from '../lib/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const categoryMapping = await getDynamicCategoryMapping();
const currentPath = Astro.url.pathname;

const languagePaths = await Promise.all(
  (Object.keys(languages) as (keyof typeof languages)[]).map(async code => ({
    code,
    label: languages[code],
    path: await getTargetLangPath(Astro.url, code, categoryMapping),
    hreflang: code === 'zh-tw' ? 'zh-TW' : code === 'zh-cn' ? 'zh-CN' : 'en',
  }))
);

const copy = {
  skip: t('a11y.skipToMain'),
  nav: t('a11y.mainNavigation'),
  selectLanguage: t('a11y.selectLanguage'),
  languageSelector: t('a11y.languageSelector'),
  openMenu: t('a11y.openMenu'),
  mobileMenu: t('a11y.mobileMenu'),
};

const isActive = (path: string) => currentPath === path || currentPath === `${path}/`;
---

<a href="#main-content" class="skip-link">{copy.skip}</a>

<nav class="nav-header" id="navbar" role="navigation" aria-label={copy.nav}>
  <div class="nav-container">
    <a href={translatePath('/')} class="nav-logo" aria-label={SITE_NAME}>
      <span class="logo-text">{SITE_NAME}</span>
    </a>

    <div class="nav-right">
      <div class="nav-links" role="list">
        <a
          href={translatePath('/')}
          class:list={['nav-item', { 'nav-item--active': isActive(translatePath('/')) }]}
          role="listitem">{t('nav.home')}</a
        >
        <a
          href={translatePath('/posts')}
          class:list={[
            'nav-item',
            {
              'nav-item--active': currentPath.includes('/posts') || currentPath.includes('/page/'),
            },
          ]}
          role="listitem">{t('nav.posts')}</a
        >
        <a
          href={translatePath('/about')}
          class:list={['nav-item', { 'nav-item--active': currentPath.includes('/about') }]}
          role="listitem">{t('nav.about')}</a
        >
      </div>

      <div class="lang-switcher">
        <button
          class="lang-trigger"
          id="lang-trigger-btn"
          aria-label={copy.selectLanguage}
          aria-expanded="false"
          aria-haspopup="listbox"
          type="button"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="19"
            height="19"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
          </svg>
        </button>
        <div
          class="lang-dropdown"
          id="lang-dropdown"
          role="listbox"
          aria-label={copy.languageSelector}
          aria-hidden="true"
        >
          {
            languagePaths.map(item => (
              <a
                href={lang === item.code ? currentPath : item.path}
                class:list={['lang-option', { 'lang-option--active': lang === item.code }]}
                role="option"
                aria-selected={lang === item.code}
                aria-disabled={lang === item.code ? 'true' : undefined}
                hreflang={item.hreflang}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>

      <button
        class="mobile-toggle"
        id="mobile-toggle"
        aria-label={copy.openMenu}
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <svg
          class="hamburger-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6" class="line-top"></line>
          <line x1="4" y1="12" x2="20" y2="12" class="line-mid"></line>
          <line x1="4" y1="18" x2="20" y2="18" class="line-bot"></line>
        </svg>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label={copy.mobileMenu}>
  <nav class="mobile-links">
    <a href={translatePath('/')} class="mobile-item">{t('nav.home')}</a>
    <a href={translatePath('/posts')} class="mobile-item">{t('nav.posts')}</a>
    <a href={translatePath('/about')} class="mobile-item">{t('nav.about')}</a>
    <div class="mobile-lang-divider" aria-hidden="true"></div>
    {
      languagePaths.map(item => (
        <a
          href={lang === item.code ? currentPath : item.path}
          class:list={['mobile-lang', { active: lang === item.code }]}
          aria-disabled={lang === item.code ? 'true' : undefined}
          hreflang={item.hreflang}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</div>

<script is:inline src="/scripts/bb-navbar.js" defer></script>

<style is:global>
  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 3000;
    transform: translateY(-160%);
    padding: 0.6rem 0.9rem;
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-heading);
    box-shadow: var(--shadow-md);
    transition: transform 0.2s ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .nav-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 2000;
    height: 70px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-nav);
    backdrop-filter: blur(16px);
    transition:
      transform 0.28s ease,
      background-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .nav-header--scrolled {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 4px 20px rgba(44, 32, 24, 0.05);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .nav-logo,
  .nav-item,
  .mobile-item,
  .mobile-lang,
  .lang-option {
    color: inherit;
    text-decoration: none;
  }

  .nav-logo {
    color: var(--text-heading);
    font-weight: 900;
  }

  .nav-right,
  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-right {
    gap: 1rem;
  }

  .nav-links {
    gap: 1.7rem;
  }

  .nav-item {
    position: relative;
    color: var(--text-secondary);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .nav-item:hover,
  .nav-item--active {
    color: var(--primary-red);
  }

  .lang-switcher {
    position: relative;
  }

  .lang-trigger,
  .mobile-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
  }

  .lang-trigger {
    padding: 0.4rem;
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 0.65rem);
    right: 0;
    min-width: 140px;
    padding: 0.45rem;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    background: var(--bg-card);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.5rem);
    transition:
      opacity 0.18s ease,
      transform 0.18s ease,
      visibility 0.18s ease;
  }

  .lang-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: block;
    padding: 0.52rem 0.75rem;
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .lang-option:hover {
    color: var(--primary-red);
    background: var(--primary-red-light);
  }

  .lang-option--active {
    color: var(--primary-red);
    background: var(--primary-red-light);
    pointer-events: none;
  }

  .mobile-toggle {
    display: none;
    padding: 0.35rem;
  }

  .hamburger-icon line {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    transform-origin: center;
  }

  .mobile-toggle.is-open .line-top {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-toggle.is-open .line-mid {
    opacity: 0;
  }

  .mobile-toggle.is-open .line-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 70px 0 0;
    z-index: 1990;
    padding: 2rem;
    background: var(--bg-main);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-0.75rem);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      visibility 0.2s ease;
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mobile-links {
    display: grid;
    gap: 0.8rem;
  }

  .mobile-item {
    color: var(--text-heading);
    font-size: 1.45rem;
    font-weight: 850;
  }

  .mobile-lang-divider {
    height: 1px;
    margin: 0.7rem 0;
    background: var(--border-color);
  }

  .mobile-lang {
    color: var(--text-secondary);
    font-weight: 700;
  }

  .mobile-lang.active,
  .mobile-lang:hover {
    color: var(--primary-red);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .mobile-toggle {
      display: inline-flex;
    }
  }
</style>
