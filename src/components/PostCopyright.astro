---
import { DEFAULT_AUTHOR } from '../lib/site';

export interface Props {
  canonicalUrl: string;
  lang: 'zh-tw' | 'en' | 'zh-cn';
  author?: string;
}

const { canonicalUrl, lang, author = DEFAULT_AUTHOR } = Astro.props;

const i = {
  title: lang === 'en' ? 'Copyright Notice' : lang === 'zh-cn' ? '\u7248\u6743\u58f0\u660e' : '\u7248\u6b0a\u8072\u660e',
  author: lang === 'en' ? 'Author' : '\u4f5c\u8005',
  canonical: lang === 'en' ? 'Canonical URL' : lang === 'zh-cn' ? '\u539f\u59cb\u94fe\u63a5' : '\u539f\u59cb\u9023\u7d50',
  badge: 'CC BY-NC-SA 4.0',
  license:
    lang === 'en'
      ? 'This article is licensed under CC BY-NC-SA 4.0.'
      : lang === 'zh-cn'
        ? '\u672c\u6587\u91c7\u7528 CC BY-NC-SA 4.0 \u6388\u6743\uff0c\u8f6c\u8f7d\u8bf7\u6ce8\u660e\u4f5c\u8005\u4e0e\u539f\u59cb\u94fe\u63a5\u3002'
        : '\u672c\u6587\u63a1\u7528 CC BY-NC-SA 4.0 \u6388\u6b0a\uff0c\u8f49\u8f09\u8acb\u8a3b\u660e\u4f5c\u8005\u8207\u539f\u59cb\u9023\u7d50\u3002',
  licenseUrl: 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
};
---

<aside
  class="post-copyright"
  aria-label={lang === 'en' ? 'Copyright notice' : lang === 'zh-cn' ? '\u7248\u6743\u58f0\u660e' : '\u7248\u6b0a\u8072\u660e'}
>
  <div class="copyright-head">
    <div class="copyright-mark" aria-hidden="true">CC</div>
    <div class="copyright-title-wrap">
      <p class="copyright-title">{i.title}</p>
      <p class="copyright-summary">{i.license}</p>
    </div>
    <a
      href={i.licenseUrl}
      rel="license noopener noreferrer"
      target="_blank"
      class="copyright-badge"
    >
      {i.badge}
    </a>
  </div>

  <dl class="copyright-meta">
    <div class="copyright-meta-item">
      <dt>{i.author}</dt>
      <dd>{author}</dd>
    </div>
    <div class="copyright-meta-item">
      <dt>{i.canonical}</dt>
      <dd>
        <a href={canonicalUrl} rel="canonical" class="copyright-link">{canonicalUrl}</a>
      </dd>
    </div>
    <div class="copyright-meta-item">
      <dt>License</dt>
      <dd>
        <a
          href={i.licenseUrl}
          rel="license noopener noreferrer"
          target="_blank"
          class="copyright-link"
        >
          Creative Commons Attribution-NonCommercial-ShareAlike 4.0
        </a>
      </dd>
    </div>
  </dl>
</aside>
