---
import HomeClockScript from './HomeClockScript.astro';
import { useTranslatedPath, useTranslations } from '../i18n/utils';

export interface Props {
  lang: 'en' | 'zh-tw' | 'zh-cn';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const secondaryLine1 = t('welcome.introSecondaryLine1');
const secondaryLine2 = t('welcome.introSecondaryLine2');
---

<section class="hero-section" aria-label={t('welcome.heroAria')}>
  <div class="hero-bg-pattern" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-card glass-card">
      <div class="clock-section">
        <div class="clock-display" aria-live="polite" aria-atomic="true">
          <div class="clock-date" id="clock-date">--/--/----</div>
          <div class="clock-time" id="clock-time">00:00:00</div>
        </div>
        <div class="timezone-selector">
          <label for="tz-select" class="tz-label">{t('welcome.timezone')}</label>
          <select id="tz-select" class="tz-select" aria-label={t('welcome.timezoneAria')}>
            <option value="auto">{t('welcome.timezoneAuto')}</option>
          </select>
        </div>
        <p id="location-msg" class="location-msg" aria-live="polite">{t('welcome.fallback')}</p>
      </div>

      <div class="hero-divider" aria-hidden="true"></div>

      <div class="intro-section">
        <h1 class="intro-title">{t('welcome.title')}</h1>
        <p class="intro-text-primary">
          <strong>{t('welcome.introPrimaryLead')}</strong>
          {t('welcome.introPrimaryRest')}
        </p>
        <p class="intro-text-secondary">
          {secondaryLine1}
          {secondaryLine1 && secondaryLine2 && <br />}
          {secondaryLine2}
        </p>
        <nav class="intro-nav" aria-label={t('welcome.actionsAria')}>
          <a href={translatePath('/posts')} class="btn-primary">{t('nav.posts')}</a>
          <a href={translatePath('/about')} class="btn-secondary">{t('nav.about')}</a>
        </nav>
      </div>
    </div>
  </div>
</section>

<HomeClockScript />

<style is:global>
  .hero-section {
    min-height: calc(80vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 3rem 1.5rem;
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(196, 122, 101, 0.08) 0%, transparent 60%),
      radial-gradient(circle at 80% 70%, rgba(196, 122, 101, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1000px;
  }

  .hero-card {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 3rem;
    border-top: 4px solid var(--primary-red);
  }

  .clock-section {
    flex: 4;
    min-width: 260px;
    text-align: center;
    padding-right: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .clock-display {
    margin: 0.5rem 0;
  }

  .clock-date {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--text-muted);
    font-family: var(--font-family-mono, monospace);
    letter-spacing: 0.05em;
  }

  .clock-time {
    font-size: 3.8rem;
    font-weight: 900;
    color: var(--text-heading);
    font-family: var(--font-family-mono, monospace);
    letter-spacing: -2px;
    line-height: 1;
    margin-top: 0.3rem;
  }

  .timezone-selector {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tz-label {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .tz-select {
    font-size: 0.82rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: rgba(253, 252, 248, 0.9);
    color: var(--text-secondary);
    cursor: pointer;
    max-width: 160px;
  }

  .location-msg {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
    min-height: 1.4em;
  }

  .hero-divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(to bottom, transparent, var(--border-color), transparent);
    flex-shrink: 0;
  }

  .intro-section {
    flex: 5;
    min-width: 280px;
    padding-left: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .intro-title {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--primary-red);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0;
  }

  .intro-text-primary {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--text-primary);
    margin: 0;
  }

  .intro-text-primary strong {
    color: var(--primary-red);
    font-weight: 800;
  }

  .intro-text-secondary {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0;
  }

  .intro-nav {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-card {
      flex-direction: column;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }

    .clock-section {
      padding-right: 0;
      width: 100%;
    }

    .hero-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
      background: linear-gradient(to right, transparent, var(--border-color), transparent);
    }

    .intro-section {
      padding-left: 0;
      width: 100%;
    }

    .clock-time {
      font-size: 3rem;
    }
  }
</style>
