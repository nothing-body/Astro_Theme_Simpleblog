---
export interface Props {
  lang?: 'zh-tw' | 'en' | 'zh-cn';
}

const { lang = 'zh-tw' } = Astro.props;

const title = lang === 'en' ? 'Bookmarks' : lang === 'zh-cn' ? '\u4e66\u7b7e' : '\u66f8\u7c64';
const description =
  lang === 'en'
    ? 'Quick links for code hosting, communities, IP lookup, and IP reputation checks.'
    : lang === 'zh-cn'
      ? '\u5e38\u7528\u7684\u4ee3\u7801\u6258\u7ba1\u3001\u793e\u533a\u3001IP \u67e5\u8be2\u4e0e IP \u98ce\u9669\u68c0\u67e5\u5165\u53e3\u3002'
      : '\u5e38\u7528\u7684\u7a0b\u5f0f\u78bc\u8a17\u7ba1\u3001\u793e\u7fa4\u3001IP \u67e5\u8a62\u8207 IP \u98a8\u96aa\u6aa2\u67e5\u5165\u53e3\u3002';

const groupLabels = {
  code: lang === 'en' ? 'Code' : lang === 'zh-cn' ? '\u4ee3\u7801' : '\u7a0b\u5f0f\u78bc',
  community: lang === 'en' ? 'Community' : lang === 'zh-cn' ? '\u793e\u533a' : '\u793e\u7fa4',
  lookup: lang === 'en' ? 'IP Lookup' : lang === 'zh-cn' ? 'IP \u67e5\u8be2' : 'IP \u67e5\u8a62',
  reputation: lang === 'en' ? 'Reputation' : lang === 'zh-cn' ? '\u98ce\u9669\u68c0\u67e5' : '\u98a8\u96aa\u6aa2\u67e5',
};

const bookmarkRows = [
  {
    group: groupLabels.code,
    items: [
      { label: 'GitHub', href: 'https://github.com/' },
      { label: 'GitLab', href: 'https://gitlab.com/' },
      { label: 'Codeberg', href: 'https://codeberg.org/' },
    ],
  },
  {
    group: groupLabels.community,
    items: [
      { label: 'nodeseek', href: 'https://www.nodeseek.com/' },
      { label: 'LowEndTalk', href: 'https://lowendtalk.com/' },
    ],
  },
  {
    group: groupLabels.lookup,
    items: [
      { label: 'ip', href: 'https://ip.net.coffee/ip/' },
      { label: 'ipaddress', href: 'https://ipaddress.my/' },
      { label: 'iplark', href: 'https://iplark.com/' },
      { label: 'ippure', href: 'https://ippure.com/' },
      { label: 'ipinfo', href: 'https://ipinfo.io/what-is-my-ip' },
    ],
  },
  {
    group: groupLabels.reputation,
    items: [
      { label: 'aubseiddb', href: 'https://www.abuseipdb.com/' },
      { label: 'scamalytics', href: 'https://scamalytics.com/ip' },
      { label: 'IPQS', href: 'https://www.ipqualityscore.com/' },
      { label: 'ip2location', href: 'https://www.ip2location.com/demo' },
    ],
  },
];
---

<section class="bookmark-panel" aria-labelledby="bookmark-title">
  <div class="bookmark-heading">
    <h3 id="bookmark-title">{title}</h3>
    <p>{description}</p>
  </div>

  <div class="bookmark-rows">
    {
      bookmarkRows.map(row => (
        <div class="bookmark-row">
          <span class="bookmark-group">{row.group}</span>
          <div class="bookmark-link-list">
            {row.items.map(item => (
              <a class="bookmark-link" href={item.href} target="_blank" rel="noopener noreferrer">
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style is:global>
  .bookmark-panel {
    position: relative;
    max-width: 860px;
    margin: 2.6rem auto 0;
    padding: 1.35rem 1.6rem 1.45rem;
    border: 1px solid rgba(196, 122, 101, 0.18);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 252, 248, 0.94), rgba(255, 255, 255, 0.86)),
      var(--card-bg, #fff);
    box-shadow:
      0 18px 42px rgba(123, 78, 62, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .bookmark-panel::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    border-radius: 8px 8px 0 0;
    background: linear-gradient(90deg, rgba(196, 122, 101, 0.2), rgba(196, 122, 101, 0.72), rgba(196, 122, 101, 0.2));
  }

  .bookmark-panel::after {
    content: '';
    position: absolute;
    top: -1.35rem;
    left: 50%;
    width: min(420px, 72%);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(196, 122, 101, 0.48), transparent);
    transform: translateX(-50%);
  }

  .bookmark-heading {
    text-align: center;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(196, 122, 101, 0.12);
  }

  .bookmark-heading h3 {
    margin: 0;
    color: var(--text-heading);
    font-size: 1.02rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .bookmark-heading p {
    margin: 0.32rem auto 0;
    max-width: 560px;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .bookmark-rows {
    display: grid;
    gap: 0.48rem;
  }

  .bookmark-row {
    display: grid;
    grid-template-columns: minmax(7.2rem, auto) 1fr;
    gap: 0.8rem;
    align-items: center;
    padding: 0.18rem 0;
    color: rgba(86, 57, 49, 0.86);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .bookmark-group {
    justify-self: end;
    padding: 0.2rem 0.58rem;
    border: 1px solid rgba(196, 122, 101, 0.18);
    border-radius: 999px;
    background: rgba(196, 122, 101, 0.07);
    color: rgba(112, 67, 55, 0.92);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.35;
    white-space: nowrap;
  }

  .bookmark-link-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .bookmark-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.02rem 0.2rem;
    color: var(--primary-red-dark, #9b4f3f);
    font-weight: 740;
    text-decoration: none;
    transition:
      color 160ms ease,
      background-color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .bookmark-link + .bookmark-link::before {
    content: '\2022';
    margin: 0 0.68rem 0 0.48rem;
    color: rgba(122, 75, 61, 0.52);
    font-weight: 600;
    pointer-events: none;
  }

  .bookmark-link:hover {
    color: var(--primary-red, #c47a65);
    border-radius: 6px;
    background: rgba(196, 122, 101, 0.07);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .bookmark-link:focus-visible {
    border-radius: 6px;
    outline: 2px solid rgba(196, 122, 101, 0.38);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .bookmark-panel {
      margin-top: 2.2rem;
      padding: 1.1rem 0.95rem 1.2rem;
    }

    .bookmark-row {
      grid-template-columns: 1fr;
      gap: 0.22rem;
      line-height: 1.8;
      text-align: center;
    }

    .bookmark-group {
      justify-self: center;
    }

    .bookmark-link {
      font-size: 0.9rem;
      min-height: 1.75rem;
    }

    .bookmark-link + .bookmark-link::before {
      margin: 0 0.48rem 0 0.32rem;
    }
  }
</style>
