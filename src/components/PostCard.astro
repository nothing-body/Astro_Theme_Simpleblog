---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { formatDate, getPostUrl, summarizePlainText } from '../lib/utils';

export interface Props {
  post: CollectionEntry<'blog'>;
  lang: Lang;
}

const { post, lang } = Astro.props;
const t = useTranslations(lang);
const postUrl = getPostUrl(post.id, lang);
const formattedDate = formatDate(post.data.pubDate, lang);
const description = post.data.description ? summarizePlainText(post.data.description, 96) : '';
const pinnedLabel = t('post.pinned');
---

<article class="post-card glass-card">
  <a href={postUrl} class="post-card-link" rel="bookmark" aria-label={post.data.title}>
    <div class="post-card-meta">
      {post.data.pinned && <span class="post-card-pinned">{pinnedLabel}</span>}
      <span class="post-card-category">{post.data.category}</span>
      <time class="post-card-date" datetime={post.data.pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <h2 class="post-card-title">{post.data.title}</h2>

    {description && <p class="post-card-desc">{description}</p>}

    <div class="post-card-footer">
      <div class="post-card-tags" aria-label={t('sidebar.tags')}>
        {post.data.tags.slice(0, 8).map((tag: string) => <span class="post-card-tag">#{tag}</span>)}
      </div>
      <span class="post-card-read" aria-hidden="true">
        {t('posts.readMore')}
      </span>
    </div>
  </a>
</article>

<style>
  .post-card {
    display: block;
    height: 100%;
    content-visibility: auto;
    contain-intrinsic-size: auto 180px;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .post-card:hover {
      transform: translateY(-5px) scale(1.01);
      box-shadow: var(--shadow-card-hover);
    }
  }

  .post-card-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.2rem;
  }

  .post-card-category {
    color: var(--primary-red);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .post-card-pinned {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    min-height: 1.45rem;
    padding: 0.16rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--primary-red) 42%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary-red) 10%, transparent);
    color: var(--primary-red);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .post-card-date {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
  }

  .post-card-title {
    margin: 0;
    color: var(--text-heading);
    font-size: 1.12rem;
    font-weight: 750;
    line-height: 1.45;
    transition: color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .post-card:hover .post-card-title {
      color: var(--primary-red);
    }
  }

  .post-card-desc {
    display: -webkit-box;
    max-height: 4.65em;
    margin: 0;
    overflow: hidden;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
    line-clamp: 3;
    overflow-wrap: anywhere;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border-color);
  }

  .post-card-tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    width: 100%;
    min-width: 0;
    overflow-x: auto;
    padding-bottom: 3px;
    scrollbar-width: none;
    mask-image: linear-gradient(to right, black 86%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 86%, transparent 100%);
  }

  .post-card-tags::-webkit-scrollbar {
    display: none;
  }

  .post-card-tag {
    color: var(--primary-red);
    font-size: 0.78rem;
    font-weight: 600;
    opacity: 0.8;
    white-space: nowrap;
    transition:
      opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card-tag:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .post-card-read {
    color: var(--primary-red);
    font-size: 0.82rem;
    font-weight: 700;
    opacity: 0.8;
    transform: translateX(-2px);
    white-space: nowrap;
    transition:
      opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card-read::after {
    content: ' ->';
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .post-card:hover .post-card-read {
      opacity: 1;
      transform: translateX(0);
    }

    .post-card:hover .post-card-read::after {
      transform: translateX(4px);
    }
  }

  @media (max-width: 480px) {
    .post-card-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .post-card-read {
      opacity: 1;
      transform: none;
    }
  }
</style>
