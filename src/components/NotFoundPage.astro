---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslatedPath, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<BaseLayout title={t('404.title')}>
  <div class="page-container not-found-page">
    <main id="main-content">
      <div class="glass-card not-found-card">
        <p class="error-code" aria-hidden="true">404</p>
        <h1 class="not-found-title">{t('404.title')}</h1>
        <p class="not-found-message">{t('404.message')}</p>
        <nav
          class="not-found-actions"
          aria-label={lang === 'en' ? '404 navigation' : lang === 'zh-cn' ? '404 导航' : '404 導覽'}
        >
          <a href={translatePath('/')} class="btn-primary">{t('404.backHome')}</a>
          <a href={translatePath('/posts')} class="btn-secondary">{t('nav.posts')}</a>
          <a href={translatePath('/about')} class="btn-secondary">{t('nav.about')}</a>
        </nav>
      </div>
    </main>
  </div>

  <style is:global>
    .not-found-page {
      padding-top: 5rem;
      padding-bottom: 5rem;
      text-align: center;
    }

    .not-found-card {
      max-width: 560px;
      margin: 0 auto;
      padding: 3.5rem 2rem;
    }

    .error-code {
      margin: 0;
      color: var(--primary-red);
      font-family: var(--font-family-mono, monospace);
      font-size: 6rem;
      font-weight: 900;
      letter-spacing: 0;
      line-height: 1;
      opacity: 0.18;
    }

    .not-found-title {
      margin: 0.8rem 0 1rem;
      color: var(--text-heading);
      font-size: 1.6rem;
      font-weight: 800;
    }

    .not-found-message {
      margin: 0 0 2rem;
      color: var(--text-secondary);
    }

    .not-found-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.85rem;
    }
  </style>
</BaseLayout>
