---

export interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl?: string;
  nextUrl?: string;
  getPageUrl: (pageNumber: number) => string;
  lang?: 'zh-tw' | 'en' | 'zh-cn';
}

const { currentPage, totalPages, prevUrl, nextUrl, getPageUrl, lang = 'zh-tw' } = Astro.props;

const prevLabel = lang === 'en' ? '← Prev' : lang === 'zh-cn' ? '← 上一页' : '← 上一頁';
const nextLabel = lang === 'en' ? 'Next →' : lang === 'zh-cn' ? '下一页 →' : '下一頁 →';

function getAriaLabel(num: number): string {
  if (lang === 'en') return `Page ${num}`;
  if (lang === 'zh-cn') return `第 ${num} 页`;
  return `第 ${num} 頁`;
}

function getPageNums(current: number, total: number): (number | null)[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

  if (current <= 4) {
    return [1, 2, 3, 4, 5, null, total];
  }

  if (current >= total - 3) {
    return [1, null, total - 4, total - 3, total - 2, total - 1, total];
  }

  return [1, null, current - 1, current, current + 1, null, total];
}

const pageNums = getPageNums(currentPage, totalPages);
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label={lang === 'en' ? 'Pagination' : '分頁導覽'}>

      {prevUrl ? (
        <a href={prevUrl} class="page-btn page-btn--nav" rel="prev" aria-label={prevLabel}>
          <span class="nav-text-full">{prevLabel}</span>
          <span class="nav-text-short">←</span>
        </a>
      ) : (
        <span class="page-btn page-btn--nav page-btn--disabled" aria-disabled="true" aria-label={prevLabel}>
          <span class="nav-text-full">{prevLabel}</span>
          <span class="nav-text-short">←</span>
        </span>
      )}

      <div class="page-numbers" role="list">
        {pageNums.map(num =>
          num === null ? (
            <span class="page-ellipsis" aria-hidden="true">
              …
            </span>
          ) : (
            <a
              href={getPageUrl(num)}
              class:list={['page-btn', { 'page-btn--active': num === currentPage }]}
              aria-label={getAriaLabel(num)}
              aria-current={num === currentPage ? 'page' : undefined}
              role="listitem"
            >
              {num}
            </a>
          )
        )}
      </div>

      {nextUrl ? (
        <a href={nextUrl} class="page-btn page-btn--nav" rel="next" aria-label={nextLabel}>
          <span class="nav-text-full">{nextLabel}</span>
          <span class="nav-text-short">→</span>
        </a>
      ) : (
        <span class="page-btn page-btn--nav page-btn--disabled" aria-disabled="true" aria-label={nextLabel}>
          <span class="nav-text-full">{nextLabel}</span>
          <span class="nav-text-short">→</span>
        </span>
      )}
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .page-numbers {
    display: flex;
    gap: 0.3rem;
    align-items: center;
  }

  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    height: 2.2rem;
    padding: 0 0.6rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .page-btn:hover {
    background: var(--primary-red-light);
    color: var(--primary-red);
    border-color: var(--primary-red);
  }

  .page-btn--active {
    background: var(--primary-red);
    color: white;
    border-color: var(--primary-red);
    pointer-events: none;
  }

  .page-btn--nav {
    padding: 0 1rem;
    font-size: 0.85rem;
  }

  .page-btn--disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  .page-ellipsis {
    color: var(--text-muted);
    padding: 0 0.2rem;
    font-size: 0.9rem;
  }

  .nav-text-full {
    display: inline;
  }

  .nav-text-short {
    display: none;
  }

  @media (max-width: 600px) {

    .nav-text-full {
      display: none;
    }
    
    .nav-text-short {
      display: inline;
    }

    .pagination {
      gap: 0.3rem;
      margin-top: 1.8rem;
    }

    .page-numbers {
      gap: 0.18rem;
    }

    .page-btn {
      min-width: 1.8rem;
      height: 1.8rem;
      padding: 0 0.3rem;
      font-size: 0.8rem;
      border-radius: 6px;
    }

    .page-btn--nav {
      padding: 0 0.45rem;
      font-size: 0.8rem;
      min-width: 1.8rem;
    }

    .page-ellipsis {
      padding: 0 0.05rem;
      font-size: 0.8rem;
    }
  }
</style>
