---

import type { CollectionEntry } from 'astro:content';

export interface Props {
  allPosts: CollectionEntry<'blog'>[];
  lang?: 'zh-tw' | 'en' | 'zh-cn';
  activeCategory?: string;
  activeTag?: string;
}

const { allPosts, lang = 'zh-tw', activeCategory, activeTag } = Astro.props;

const pathPrefix = lang === 'en' ? '' : `/${lang}`;
const postsHref = `${pathPrefix}/posts`;
const categoryLabel = lang === 'en' ? 'Categories' : '文章分類';
const tagLabel = lang === 'en' ? 'Tags' : '標籤';

const categoryMap = new Map<string, number>();
for (const post of allPosts) {
  const cat = post.data.category;
  categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}
const categoriesList = [...categoryMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
---

<aside class="sidebar" aria-label={lang === 'en' ? 'Sidebar' : '側邊欄'}>
  <!-- 分類列表 -->
  <div class="glass-card sidebar-widget">
    <h3 class="widget-title">{categoryLabel}</h3>
    <ul class="category-list" role="list">
      {
        categoriesList.map(([cat, count]) => (
          <li role="listitem">
            <a
              href={cat === activeCategory ? postsHref : `${pathPrefix}/categories/${encodeURIComponent(cat)}/1`}
              class:list={['cat-link', { 'cat-link--active': cat === activeCategory }]}
              data-sidebar-filter-link
              data-filter-kind="category"
              data-filter-value={cat}
              data-filter-active={cat === activeCategory ? 'true' : 'false'}
              aria-current={cat === activeCategory ? 'page' : undefined}
            >
              <span>{cat}</span>
              <span class="cat-count">{count}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- 標籤雲 -->
  <div class="glass-card sidebar-widget">
    <h3 class="widget-title">{tagLabel}</h3>
    <div class="tag-cloud" role="list">
      {
        allTags.map(tag => (
          <a
            href={tag === activeTag ? postsHref : `${pathPrefix}/tags/${encodeURIComponent(tag)}/1`}
            class:list={['tag-box', { 'tag-box--active': tag === activeTag }]}
            data-sidebar-filter-link
            data-filter-kind="tag"
            data-filter-value={tag}
            data-filter-active={tag === activeTag ? 'true' : 'false'}
            aria-current={tag === activeTag ? 'page' : undefined}
            role="listitem"
          >
            #{tag}
          </a>
        ))
      }
    </div>
  </div>
</aside>

<script>
  (() => {
    const prefetched = new Set<string>();

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-sidebar-filter-link]')
    );

    const isPlainLeftClick = (event: MouseEvent) =>
      event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey;

    const markPending = (link: HTMLAnchorElement) => {
      const kind = link.dataset.filterKind;
      const returnsToAllPosts = link.dataset.filterActive === 'true';

      for (const item of links) {
        const itemKind = item.dataset.filterKind;
        if (itemKind === 'category') {
          item.classList.remove('cat-link--active');
        }
        if (itemKind === 'tag') {
          item.classList.remove('tag-box--active');
        }
        item.removeAttribute('aria-current');
      }

      if (!returnsToAllPosts && kind === 'category') {
        link.classList.add('cat-link--active');
        link.setAttribute('aria-current', 'page');
      }

      if (!returnsToAllPosts && kind === 'tag') {
        link.classList.add('tag-box--active');
        link.setAttribute('aria-current', 'page');
      }

      document.querySelector('#main-content')?.setAttribute('aria-busy', 'true');
    };

    const prefetch = (link: HTMLAnchorElement) => {
      const href = link.href;
      if (!href || prefetched.has(href)) return;

      const target = new URL(href, window.location.href);
      if (target.origin !== window.location.origin) return;

      const hint = document.createElement('link');
      hint.rel = 'prefetch';
      hint.href = target.href;
      document.head.append(hint);
      prefetched.add(href);
    };

    for (const link of links) {
      link.addEventListener('click', event => {
        if (!isPlainLeftClick(event)) return;
        markPending(link);
      });
      link.addEventListener('pointerenter', () => prefetch(link), { passive: true });
      link.addEventListener('focus', () => prefetch(link), { passive: true });
    }
  })();
</script>

<style is:global>
  .sidebar-widget {
    padding: 1.2rem 1.3rem;
    margin-bottom: 1.2rem;
  }
  .sidebar-widget:last-child {
    margin-bottom: 0;
  }

  .cat-count {
    background: var(--primary-red-light);
    color: var(--primary-red);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
    min-width: 1.4rem;
    text-align: center;
  }
</style>
