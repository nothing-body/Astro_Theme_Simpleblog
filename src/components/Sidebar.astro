---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import CategoryTree from './CategoryTree.astro';
import { buildCategoryTree, getCategoryPathKey } from '../lib/categories';

export interface Props {
  allPosts: CollectionEntry<'blog'>[];
  lang?: 'zh-tw' | 'en' | 'zh-cn';
  activeCategory?: string;
  activeCategoryPath?: string[];
  activeTag?: string;
}

const { allPosts, lang = 'zh-tw', activeCategory, activeCategoryPath, activeTag } = Astro.props;
const t = useTranslations(lang);

const pathPrefix = lang === 'en' ? '' : `/${lang}`;
const postsHref = `${pathPrefix}/posts`;
const categoryLabel = t('sidebar.categories');
const tagLabel = t('sidebar.tags');
const sidebarLabel = t('sidebar.label');

const normalizedActivePath = activeCategoryPath ?? (activeCategory ? [activeCategory] : []);
const activePathKey =
  normalizedActivePath.length > 0 ? getCategoryPathKey(normalizedActivePath) : undefined;
const globalPosts = await getCollection('blog', ({ data }) => !data.draft);
const categoryTree = buildCategoryTree(allPosts, lang, normalizedActivePath, globalPosts);

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
---

<aside class="sidebar" aria-label={sidebarLabel}>
  <div class="glass-card sidebar-widget">
    <h3 class="widget-title">{categoryLabel}</h3>
    <CategoryTree
      nodes={categoryTree}
      lang={lang}
      postsHref={postsHref}
      activePathKey={activePathKey}
    />
  </div>

  <div class="glass-card sidebar-widget tags-widget">
    <h3 class="widget-title">{tagLabel}</h3>
    <div class="tag-cloud" role="list">
      {
        allTags.map(tag => (
          <a
            href={tag === activeTag ? postsHref : `${pathPrefix}/tags/${encodeURIComponent(tag)}/1`}
            class:list={['tag-box', { 'tag-box--active': tag === activeTag }]}
            data-sidebar-filter-link
            data-filter-kind="tag"
            data-filter-value={tag}
            data-filter-active={tag === activeTag ? 'true' : 'false'}
            aria-current={tag === activeTag ? 'page' : undefined}
            role="listitem"
          >
            #{tag}
          </a>
        ))
      }
    </div>
  </div>
</aside>

<script is:inline src="/scripts/bb-sidebar.js" defer></script>

<style is:global>
  .sidebar-widget:last-child {
    margin-bottom: 0;
  }

  .cat-count {
    min-width: 1.4rem;
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
    background: var(--primary-red-light);
    color: var(--primary-red);
    font-size: 0.75rem;
    font-weight: 700;
    text-align: center;
  }
</style>
