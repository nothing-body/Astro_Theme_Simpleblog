---
import { getSiteUrl } from '../lib/site';
import { safeJsonStringify } from '../lib/utils';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const siteUrl = getSiteUrl(Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, siteUrl).href } : {}),
  })),
};
---

<!-- BreadcrumbList 結構化資料 -->
<script is:inline type="application/ld+json" set:html={safeJsonStringify(jsonLd)} />

<nav class="breadcrumbs" aria-label="麵包屑導航">
  <ol class="breadcrumb-list" role="list">
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;
        return (
          <li class="breadcrumb-item" role="listitem">
            {!isLast && item.href ? (
              <>
                <a href={item.href} class="breadcrumb-link">
                  {item.label}
                </a>
                <span class="breadcrumb-sep" aria-hidden="true">
                  &gt;
                </span>
              </>
            ) : (
              <span class="breadcrumb-current" aria-current="page">
                {item.label}
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
