---
// src/pages/en/categories/[category]/[page].astro — English category pages
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { sortBlogPosts } from '../../../lib/posts';

export async function getStaticPaths() {
  const PAGE_SIZE = 5;
  const allPosts = await getCollection(
    'blog',
    ({ id, data }) => id.startsWith('en/') && !data.draft
  );
  const categoryMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    const cat = post.data.category;
    if (!categoryMap.has(cat)) categoryMap.set(cat, []);
    categoryMap.get(cat)!.push(post);
  }
  const paths: {
    params: { category: string; page: string };
    props: {
      allPosts: typeof allPosts;
      categoryPosts: typeof allPosts;
      currentCategory: string;
      totalPages: number;
    };
  }[] = [];
  for (const [cat, catPosts] of categoryMap) {
    const sorted = sortBlogPosts(catPosts);
    const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
    for (let i = 1; i <= totalPages; i++) {
      paths.push({
        params: { category: cat, page: String(i) },
        props: { allPosts, categoryPosts: sorted, currentCategory: cat, totalPages },
      });
    }
  }
  return paths;
}

const { allPosts, categoryPosts, currentCategory, totalPages } = Astro.props;
const PAGE_SIZE = 5;
const currentPage = Number(Astro.params.page);
const posts = categoryPosts.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
const getPageUrl = (n: number) => `/categories/${encodeURIComponent(currentCategory)}/${n}`;
---

<BaseLayout title={`${currentCategory} — Category`}>
  <div class="page-container" style="padding-top:2rem; padding-bottom:4rem;">
    <div class="content-wrapper">
      <Sidebar allPosts={allPosts} lang="en" activeCategory={currentCategory} />
      <main id="main-content" class="main-content">
        <h1
          style="font-size:1.6rem; font-weight:800; color:var(--text-heading); margin-bottom:1.5rem;"
        >
          Category: {currentCategory}
        </h1>
        {posts.map(post => <PostCard post={post} lang="en" />)}
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          prevUrl={currentPage > 1 ? getPageUrl(currentPage - 1) : undefined}
          nextUrl={currentPage < totalPages ? getPageUrl(currentPage + 1) : undefined}
          getPageUrl={getPageUrl}
          lang="en"
        />
      </main>
    </div>
  </div>

  <script>
    try {
      sessionStorage.setItem('bb-last-list', window.location.pathname);
    } catch {}
  </script>
</BaseLayout>
