---
// src/pages/en/disclaimer.astro — Disclaimer (English)
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutSidebar from '../components/AboutSidebar.astro';
import { getCanonicalUrl } from '../lib/site';
import { safeJsonStringify } from '../lib/utils';

const currentPath = Astro.url.pathname;
const pageUrl = getCanonicalUrl(currentPath, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Disclaimer',
  url: pageUrl,
  description: 'Disclaimer for this site, explaining content usage and liability.',
  publisher: { '@type': 'Person', name: 'Astro Blog Template' },
};
---

<BaseLayout
  title="Disclaimer"
  description="Disclaimer for this site, explaining content usage and liability."
>
  <script is:inline type="application/ld+json" set:html={safeJsonStringify(jsonLd)} />
  <div class="page-container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="content-wrapper">
      <AboutSidebar lang="en" currentPath={currentPath} />
      <main id="main-content" class="main-content">
        <article class="glass-card" style="padding: 2.5rem;">
          <div class="article-entry">
            <h1>Disclaimer</h1>
            <p>Please read the following disclaimer carefully before using this site's content:</p>

            <h2>Accuracy of Content</h2>
            <p>
              The content published on this site consists primarily of the author's personal
              learning notes, technical write-ups, and subjective opinions. We do not guarantee the
              absolute accuracy or timeliness of any technical solutions or software information
              described. Technology evolves rapidly — please conduct your own evaluation and testing
              before applying anything to a production environment, and always back up your data.
            </p>

            <h2>External Links</h2>
            <p>
              This site contains links to third-party websites. We are not responsible for the
              content, privacy policies, or security of those external sites.
            </p>

            <h2>Liability</h2>
            <p>
              The author assumes no legal or financial responsibility for any data loss, equipment
              damage, or other losses resulting from following advice or recommendations found on
              this site.
            </p>
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>
