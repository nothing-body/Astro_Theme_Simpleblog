---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeHero from '../../components/HomeHero.astro';
import HomeLatestPosts from '../../components/HomeLatestPosts.astro';
import { getRecentPostsForLang } from '../../lib/posts';
import { getSiteUrl } from '../../lib/site';
import { safeJsonStringify } from '../../lib/utils';

const recentPosts = await getRecentPostsForLang('zh-cn');
const description = '分享软件心得、VPS 配置以及日常随笔的个人博客。';

const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: "Astro Blog Template",
  description,
  url: pageUrl,
  publisher: { '@type': 'Person', name: "Astro Blog Template", '@id': siteUrl },
};
---

<BaseLayout title="Astro Blog Template" description={description}>
  <script is:inline type="application/ld+json" set:html={safeJsonStringify(jsonLd)} />

  <HomeHero lang="zh-cn" />
  <HomeLatestPosts lang="zh-cn" posts={recentPosts} />
</BaseLayout>
