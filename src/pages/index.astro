---
// src/pages/index.astro — 繁體中文首頁
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import { sortBlogPosts } from '../lib/posts';
import { getSiteUrl } from '../lib/site';
import { safeJsonStringify } from '../lib/utils';

const t = useTranslations('zh-tw');

// 取得最新 3 篇已發佈文章（zh-tw）
const allPosts = await getCollection(
  'blog',
  ({ id, data }) => id.startsWith('zh-tw/') && !data.draft
);
const recentPosts = sortBlogPosts(allPosts).slice(0, 3);

const siteUrl = getSiteUrl(Astro.site);
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

// 網站 JSON-LD
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Astro Blog Template',
  description:
    '分享軟體使用心得、記錄/分享查找到的有趣/實用軟體、生活日常與隨手小記的個人網站與數位筆記',
  url: pageUrl,
  publisher: {
    '@type': 'Person',
    name: 'Astro Blog Template',
    '@id': siteUrl,
  },
};
---

<BaseLayout
  title="Astro Blog Template"
  description="分享軟體使用心得、記錄查找到的有趣/實用軟體、生活日常與隨手小記的個人部落格。"
>
  <!-- Blog JSON-LD -->
  <script is:inline type="application/ld+json" set:html={safeJsonStringify(websiteJsonLd)} />

  <!-- ===== Hero 區塊 ===== -->
  <section class="hero-section" aria-label="歡迎">
    <div class="hero-bg-pattern" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-card glass-card">
        <!-- 時鐘區 -->
        <div class="clock-section">
          <div class="clock-display" aria-live="polite" aria-atomic="true">
            <div class="clock-date" id="clock-date" aria-label="日期">--/--/----</div>
            <div class="clock-time" id="clock-time" aria-label="時間">00:00:00</div>
          </div>

          <div class="timezone-selector">
            <label for="tz-select" class="tz-label">選擇時區：</label>
            <select id="tz-select" class="tz-select" aria-label="時區選擇">
              <option value="auto">自動檢測</option>
            </select>
          </div>

          <p id="location-msg" class="location-msg" aria-live="polite">歡迎來到我的個人隨筆空間</p>
        </div>

        <!-- 分隔線 -->
        <div class="hero-divider" aria-hidden="true"></div>

        <!-- 簡介區 -->
        <div class="intro-section">
          <h1 class="intro-title">{t('welcome.title')}</h1>
          <p class="intro-text-primary">
            <strong>歡迎來到我的個人部落格！</strong>
            這是一個隨手的數位筆記空間。
          </p>
          <p class="intro-text-secondary">
            記錄我個人發現的實用軟體和介紹、一些 VPS 個人設定配置，以及日常思考隨筆。<br />
            期望能在我需要時不需再次辛苦搜尋資料，同時如果這些記錄能為你帶來參考價值，那就太好了。
          </p>
          <nav class="intro-nav" aria-label="主要動作">
            <a href="/posts" class="btn-primary">{t('nav.posts')}</a>
            <a href="/about" class="btn-secondary">{t('nav.about')}</a>
          </nav>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 最新文章 ===== -->
  <section class="latest-section page-container" aria-label="最新文章">
    <h2 class="section-title">
      <span>{t('posts.latestPosts')}</span>
    </h2>

    {
      recentPosts.length > 0 ? (
        <div class="posts-grid">
          {recentPosts.map(post => (
            <PostCard post={post} lang="zh-tw" />
          ))}
        </div>
      ) : (
        <p class="no-posts">{t('posts.noPost')}</p>
      )
    }

    <div class="view-all">
      <a href="/posts" class="btn-primary">{t('nav.posts')}</a>
    </div>
  </section>


<!-- 時鐘腳本 -->
<script>
  let tzValue = 'auto';
  let clockTimer: ReturnType<typeof setInterval> | null = null;
  const TZ_KEY = 'bb-tz';

  function updateClock(): void {
    const now = new Date();
    const tz = tzValue === 'auto' ? undefined : tzValue;

    const dateParts = new Intl.DateTimeFormat('en-GB', {
      timeZone: tz,
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
    }).formatToParts(now);
    const timeParts = new Intl.DateTimeFormat('en-GB', {
      timeZone: tz,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).formatToParts(now);

    const get = (parts: Intl.DateTimeFormatPart[], type: string) =>
      parts.find(p => p.type === type)?.value ?? '--';

    const dateEl = document.getElementById('clock-date');
    const timeEl = document.getElementById('clock-time');
    if (dateEl)
      dateEl.textContent = `${get(dateParts, 'day')}/${get(dateParts, 'month')}/${get(dateParts, 'year')}`;
    if (timeEl)
      timeEl.textContent = `${get(timeParts, 'hour')}:${get(timeParts, 'minute')}:${get(timeParts, 'second')}`;
  }

  function startClock(): void {
    if (clockTimer !== null) return;
    updateClock();
    clockTimer = setInterval(updateClock, 1000);
  }

  function stopClock(): void {
    if (clockTimer !== null) {
      clearInterval(clockTimer);
      clockTimer = null;
    }
  }

  // 頁面隱藏時暫停時鐘，節省資源
  document.addEventListener('visibilitychange', () => {
    document.hidden ? stopClock() : startClock();
  });

  startClock();

  // 初始化時區選擇器
  const tzSelect = document.getElementById('tz-select') as HTMLSelectElement | null;
  if (tzSelect) {
    let tzList: string[] = [
      'UTC',
      'Asia/Taipei',
      'Asia/Tokyo',
      'Asia/Hong_Kong',
      'America/New_York',
      'America/Los_Angeles',
      'Europe/London',
      'Europe/Paris',
    ];
    try {
      tzList = Intl.supportedValuesOf('timeZone');
    } catch {}

    tzList.forEach(tz => {
      const opt = document.createElement('option');
      opt.value = tz;
      opt.textContent = tz;
      tzSelect.appendChild(opt);
    });

    // 讀取儲存的時區（需使用者同意才讀取）
    const privacyOk =
      window.__privacySettings?.rememberTimezone && window.__privacySettings?.hasSetCookies;
    const savedTz = privacyOk
      ? (() => {
          try {
            return localStorage.getItem(TZ_KEY);
          } catch {
            return null;
          }
        })()
      : null;

    if (savedTz) {
      tzValue = savedTz;
      tzSelect.value = savedTz;
    }

    tzSelect.addEventListener('change', () => {
      tzValue = tzSelect.value;
      updateClock();
      // 僅在使用者同意下儲存
      if (window.__privacySettings?.rememberTimezone && window.__privacySettings?.hasSetCookies) {
        try {
          localStorage.setItem(TZ_KEY, tzValue);
        } catch {}
      } else {
        try {
          localStorage.removeItem(TZ_KEY);
        } catch {}
      }
    });
  }
</script>

<style is:global>
  /* Hero 區塊 */
  .hero-section {
    min-height: calc(80vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 3rem 1.5rem;
  }

  /* 背景紋理 */
  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(196, 122, 101, 0.08) 0%, transparent 60%),
      radial-gradient(circle at 80% 70%, rgba(196, 122, 101, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1000px;
  }

  .hero-card {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 3rem;
    border-top: 4px solid var(--primary-red);
  }

  /* 時鐘區 */
  .clock-section {
    flex: 4;
    min-width: 260px;
    text-align: center;
    padding-right: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .clock-display {
    margin: 0.5rem 0;
  }

  .clock-date {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--text-muted);
    font-family: var(--font-family-mono, monospace);
    letter-spacing: 0.05em;
  }

  .clock-time {
    font-size: 3.8rem;
    font-weight: 900;
    color: var(--text-heading);
    font-family: var(--font-family-mono, monospace);
    letter-spacing: -2px;
    line-height: 1;
    margin-top: 0.3rem;
  }

  .timezone-selector {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tz-label {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .tz-select {
    font-size: 0.82rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: rgba(253, 252, 248, 0.9);
    color: var(--text-secondary);
    cursor: pointer;
    max-width: 160px;
  }

  .location-msg {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
    min-height: 1.4em;
  }

  /* 垂直分隔線 */
  .hero-divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(to bottom, transparent, var(--border-color), transparent);
    flex-shrink: 0;
  }

  /* 簡介區 */
  .intro-section {
    flex: 5;
    min-width: 280px;
    padding-left: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .intro-title {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--primary-red);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0;
  }

  .intro-text-primary {
    font-size: 1.18rem;
    line-height: 1.7;
    color: var(--text-heading);
    font-weight: 550;
    margin: 0;
  }

  .intro-text-primary strong {
    color: var(--primary-red);
    font-weight: 800;
  }

  .intro-text-secondary {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-primary);
    font-weight: 500;
    margin: 0;
  }

  .intro-nav {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  /* 最新文章區 */
  .latest-section {
    padding-top: 1rem;
    padding-bottom: 5rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-heading);
    text-align: center;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .section-title::before,
  .section-title::after {
    content: '';
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: var(--border-color);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .no-posts {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
  }

  .view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* 響應式 */
  @media (max-width: 768px) {
    .hero-card {
      flex-direction: column;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    }
    .clock-section {
      padding-right: 0;
      width: 100%;
    }
    .hero-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
      background: linear-gradient(to right, transparent, var(--border-color), transparent);
    }
    .intro-section {
      padding-left: 0;
      width: 100%;
    }
    .clock-time {
      font-size: 3rem;
    }
    .intro-text-primary {
      font-size: 1.12rem;
    }
    .intro-text-secondary {
      font-size: 1.02rem;
    }
  }

  @media (max-width: 480px) {
    .clock-time {
      font-size: 2.5rem;
    }
    .intro-nav {
      flex-direction: column;
    }
    .intro-nav .btn-primary,
    .intro-nav .btn-secondary {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
    .intro-text-primary {
      font-size: 1.08rem;
    }
    .intro-text-secondary {
      font-size: 1rem;
    }
  }
</style>
</BaseLayout>
