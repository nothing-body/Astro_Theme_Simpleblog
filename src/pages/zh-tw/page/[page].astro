---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import PostCard from '../../../components/PostCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { useTranslations } from '../../../i18n/utils';
import { sortBlogPosts } from '../../../lib/posts';

export async function getStaticPaths() {
  const PAGE_SIZE = 5;
  const allPosts = await getCollection(
    'blog',
    ({ id, data }) => id.startsWith('zh-tw/') && !data.draft
  );
  const sorted = sortBlogPosts(allPosts);
  const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
    props: { totalPages, allPosts: sorted },
  }));
}

const { page } = Astro.params;
const { totalPages, allPosts } = Astro.props;

const t = useTranslations('zh-tw');
const PAGE_SIZE = 5;
const currentPage = Number(page);
const posts = allPosts.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);

const getPageUrl = (n: number) => (n === 1 ? '/zh-tw/posts' : `/zh-tw/page/${n}`);
const prevUrl = currentPage > 1 ? getPageUrl(currentPage - 1) : undefined;
const nextUrl = currentPage < totalPages ? getPageUrl(currentPage + 1) : undefined;
---

<BaseLayout
  title={`${t('posts.title')} — 第 ${currentPage} 頁`}
  description={`所有文章列表第 ${currentPage} 頁`}
>
  <div class="page-container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="content-wrapper">
      <Sidebar allPosts={allPosts} lang="zh-tw" />
      <main id="main-content" class="main-content">
        <h1
          style="font-size:1.6rem; font-weight:800; color:var(--text-heading); margin-bottom:1.5rem;"
        >
          {t('posts.title')}
        </h1>
        {posts.map(post => <PostCard post={post} lang="zh-tw" />)}
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          prevUrl={prevUrl}
          nextUrl={nextUrl}
          getPageUrl={getPageUrl}
          lang="zh-tw"
        />
      </main>
    </div>
  </div>

  <script is:inline src="/scripts/bb-last-list.js" defer></script>
</BaseLayout>
