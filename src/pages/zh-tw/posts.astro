---

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { useTranslations } from '../../i18n/utils';
import { sortBlogPosts } from '../../lib/posts';
import { getSiteUrl } from '../../lib/site';

const t = useTranslations('zh-tw');

const PAGE_SIZE = 5;

const allPosts = await getCollection(
  'blog',
  ({ id, data }) => id.startsWith('zh-tw/') && !data.draft
);
const sortedPosts = sortBlogPosts(allPosts);

const totalPages = Math.max(1, Math.ceil(sortedPosts.length / PAGE_SIZE));
const posts = sortedPosts.slice(0, PAGE_SIZE);

const siteUrl = getSiteUrl(Astro.site);
const canonicalPage1 = new URL('/zh-tw/page/1', siteUrl).href;
---

<BaseLayout
  title={t('posts.title')}
  description="所有文章列表 — 瀏覽所有技術隨筆與生活小記。"
  customCanonical={canonicalPage1}
>
  <div class="page-container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="content-wrapper">
      <Sidebar allPosts={allPosts} lang="zh-tw" />
      <main id="main-content" class="main-content">
        <h1
          style="font-size:1.6rem; font-weight:800; color:var(--text-heading); margin-bottom:1.5rem;"
        >
          {t('posts.title')}
        </h1>
        {
          posts.length > 0 ? (
            <>
              {posts.map(post => (
                <PostCard post={post} lang="zh-tw" />
              ))}
              <Pagination
                currentPage={1}
                totalPages={totalPages}
                nextUrl={totalPages > 1 ? '/zh-tw/page/2' : undefined}
                getPageUrl={n => (n === 1 ? '/zh-tw/posts' : `/zh-tw/page/${n}`)}
                lang="zh-tw"
              />
            </>
          ) : (
            <p style="color:var(--text-muted); padding: 3rem 0;">{t('posts.noPost')}</p>
          )
        }
      </main>
    </div>
  </div>

  <script>

    try {
      sessionStorage.setItem('bb-last-list', window.location.pathname);
    } catch {}
  </script>
</BaseLayout>
