---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PostCopyright from '../components/PostCopyright.astro';
import {
  getDynamicCategoryMapping,
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from '../i18n/utils';
import { formatDate, safeJsonStringify, summarizePlainText } from '../lib/utils';
import { DEFAULT_AUTHOR, SITE_NAME, getSiteUrl } from '../lib/site';
import '../styles/markdown.css';
import '../assets/css/blog-enhancements.css';

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    pubDate: Date;
    updatedDate?: Date;
    category?: string;
    tags?: string[];
    author?: string;
    ogImage?: string;
  };
}

const { frontmatter } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categoryMapping = await getDynamicCategoryMapping();
const uncategorized =
  lang === 'en' ? 'Uncategorized' : lang === 'zh-cn' ? '\u672a\u5206\u7c7b' : '\u672a\u5206\u985e';
const currentCategory = frontmatter.category ?? uncategorized;

const publishedDate = new Date(frontmatter.pubDate);
const updatedDate = frontmatter.updatedDate ? new Date(frontmatter.updatedDate) : undefined;
const formattedDate = formatDate(publishedDate, lang);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = getSiteUrl(Astro.site);
const articleDescription = summarizePlainText(frontmatter.description ?? frontmatter.title, 180);
const updatedLabel = lang === 'en' ? 'Updated: ' : lang === 'zh-cn' ? '\u66f4\u65b0\uff1a' : '\u66f4\u65b0\uff1a';
const tagsLabel = lang === 'en' ? 'Post tags' : lang === 'zh-cn' ? '\u6587\u7ae0\u6807\u7b7e' : '\u6587\u7ae0\u6a19\u7c64';
const backNavLabel =
  lang === 'en' ? 'Post navigation' : lang === 'zh-cn' ? '\u6587\u7ae0\u5bfc\u822a' : '\u6587\u7ae0\u5c0e\u89bd';
const breadcrumbLabel =
  lang === 'en' ? 'Breadcrumb navigation' : lang === 'zh-cn' ? '\u9762\u5305\u5c51\u5bfc\u822a' : '\u9eb5\u5305\u5c51\u5c0e\u89bd';

const breadcrumbs = [
  { label: t('breadcrumb.home'), href: translatePath('/') },
  { label: t('breadcrumb.posts'), href: translatePath('/posts') },
  {
    label: currentCategory,
    href: translatePath(`/categories/${encodeURIComponent(currentCategory)}/1`),
  },
  { label: frontmatter.title },
];
---

<BaseLayout
  title={frontmatter.title}
  description={articleDescription}
  canonicalUrl={canonicalUrl}
  ogImage={frontmatter.ogImage}
  pubDate={publishedDate}
  updatedDate={updatedDate}
  type="article"
  tags={frontmatter.tags}
  category={currentCategory}
  author={frontmatter.author}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={safeJsonStringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: frontmatter.title,
      description: articleDescription,
      datePublished: publishedDate.toISOString(),
      dateModified: (updatedDate ?? publishedDate).toISOString(),
      author: {
        '@type': 'Person',
        name: frontmatter.author ?? DEFAULT_AUTHOR,
      },
      publisher: {
        '@type': 'Person',
        name: SITE_NAME,
        url: siteUrl,
      },
      articleSection: currentCategory,
      keywords: (frontmatter.tags ?? []).join(', '),
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
    })}
  />

  <div class="be-article-wrapper">
    <div class="immersion-read-container be-content">
      <article class="post-article">
        <Breadcrumbs items={breadcrumbs} ariaLabel={breadcrumbLabel} />

        <header class="post-header">
          <div class="post-meta-row">
            <a
              href={translatePath(`/categories/${encodeURIComponent(currentCategory)}/1`)}
              class="post-category-badge"
            >
              {currentCategory}
            </a>
            <span class="meta-dot" aria-hidden="true">/</span>
            <time class="post-date" datetime={publishedDate.toISOString()}>{formattedDate}</time>
            {
              updatedDate && (
                <>
                  <span class="meta-dot" aria-hidden="true">
                    /
                  </span>
                  <span class="post-updated">
                    {updatedLabel}
                    <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate, lang)}</time>
                  </span>
                </>
              )
            }
          </div>

          <h1 class="post-main-title">{frontmatter.title}</h1>

          {
            (frontmatter.tags ?? []).length > 0 && (
              <div class="post-tags-row" aria-label={tagsLabel}>
                {(frontmatter.tags ?? []).map((tag: string) => (
                  <a href={translatePath(`/tags/${encodeURIComponent(tag)}/1`)} class="inline-tag">
                    #{tag}
                  </a>
                ))}
              </div>
            )
          }

          <div class="post-divider" role="separator" aria-hidden="true"></div>
        </header>

        <div class="article-entry">
          <slot />
        </div>

        <PostCopyright canonicalUrl={canonicalUrl} lang={lang} author={frontmatter.author} />

        <footer class="post-footer">
          <div class="post-footer-hr" aria-hidden="true"></div>
          <nav class="post-back-nav" aria-label={backNavLabel}>
            <a href={translatePath('/posts')} class="back-link" id="post-back-link">
              {t('nav.backToPosts')}
            </a>
          </nav>
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ lang, categoryMapping, currentCategory }}>
  window.addEventListener('DOMContentLoaded', () => {
    try {
      const backLink = document.getElementById('post-back-link');
      if (!(backLink instanceof HTMLAnchorElement)) return;

      let lastPath = sessionStorage.getItem('bb-last-list');
      const currentPath = window.location.pathname;

      if (!lastPath || lastPath === currentPath || !/^\/[^/]/.test(lastPath)) return;

      const getPathLang = path => {
        if (path.startsWith('/zh-tw/') || path === '/zh-tw') return 'zh-tw';
        if (path.startsWith('/zh-cn/') || path === '/zh-cn') return 'zh-cn';
        return 'en';
      };

      const lastLang = getPathLang(lastPath);

      if (lastLang !== lang) {
        const parts = lastPath.split('/').filter(Boolean);
        const hasPrefix = parts[0] === 'zh-tw' || parts[0] === 'zh-cn';

        if (lastPath.includes('/categories/')) {
          const catName = decodeURIComponent(parts[hasPrefix ? 2 : 1] ?? '');
          const targetCat = categoryMapping[catName] ?? currentCategory;
          const catPath = `/categories/${encodeURIComponent(targetCat)}/1`;
          lastPath = lang === 'en' ? catPath : `/${lang}${catPath}`;
        } else if (lastPath.includes('/tags/')) {
          const tagName = decodeURIComponent(parts[hasPrefix ? 2 : 1] ?? '');
          const tagPath = `/tags/${encodeURIComponent(tagName)}/1`;
          lastPath = lang === 'en' ? tagPath : `/${lang}${tagPath}`;
        } else {
          lastPath = lang === 'en' ? '/posts' : `/${lang}/posts`;
        }
      }

      backLink.href = lastPath;
    } catch {}
  });
</script>

<style is:global>
  .immersion-read-container {
    max-width: 1100px;
    margin: 1.5rem auto 5rem;
    padding: 0 1.5rem;
  }

  .post-article {
    flex-grow: 1;
    min-width: 0;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-top: 0.5rem;
  }

  .post-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.8rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 500;
  }

  .post-category-badge {
    padding: 0.15rem 0.55rem;
    border-radius: 99px;
    background: var(--primary-red-light);
    color: var(--primary-red);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .post-category-badge:hover {
    background: var(--primary-red);
    color: white;
  }

  .meta-dot {
    opacity: 0.3;
  }

  .post-date,
  .post-updated {
    color: var(--text-muted);
  }

  .post-updated {
    font-size: 0.82rem;
  }

  .post-main-title {
    margin: 0.5rem 0 1.2rem;
    color: var(--text-heading);
    font-size: clamp(2rem, 5.5vw, 3rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.22;
    word-break: break-word;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .be-article-wrapper {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .post-tags-row {
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    width: 100%;
    min-width: 0;
    margin-bottom: 0.8rem;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
    mask-image: linear-gradient(to right, black 88%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 88%, transparent 100%);
  }

  .post-tags-row::-webkit-scrollbar {
    display: none;
  }

  .inline-tag {
    color: var(--primary-red);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition:
      opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .inline-tag:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  .post-divider {
    height: 2px;
    margin-top: 1.5rem;
    border-radius: 2px;
    background: linear-gradient(
      to right,
      var(--primary-red),
      rgba(196, 122, 101, 0.3),
      transparent
    );
    opacity: 0.6;
  }

  .post-footer {
    margin-top: 3.5rem;
  }

  .post-footer-hr {
    height: 1px;
    margin-bottom: 2rem;
    background: var(--border-color);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--primary-red);
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    gap: 0.5rem;
    color: var(--primary-red-dark);
  }

  @media (max-width: 768px) {
    .immersion-read-container {
      margin: 1rem auto 3rem;
      padding: 0 0.75rem;
    }

    .post-header {
      margin-bottom: 2rem;
    }

    .post-main-title {
      margin: 0.3rem 0 0.8rem;
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .post-meta-row {
      gap: 6px;
      font-size: 0.82rem;
    }

    .post-category-badge {
      padding: 0.12rem 0.45rem;
      font-size: 0.72rem;
    }

    .post-tags-row {
      gap: 8px;
    }

    .inline-tag {
      font-size: 0.8rem;
    }

    .post-footer {
      margin-top: 2.5rem;
    }
  }
</style>
