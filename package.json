{
  "name": "blue-binary",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "devalue": ">=5.8.1"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:switch": "node ./scripts/deploy_switch.mjs",
    "deploy:cf:only": "node ./scripts/uploaddist_cf.mjs",
    "deploy:vps:only": "node ./scripts/uploaddist_vps.mjs",
    "deploy:vercel:only": "node ./scripts/uploaddist_vercel.mjs",
    "deploy:cf:vps": "node ./scripts/deploy_switch.mjs --mode=direct:cf+vps",
    "deploy:cf:vercel": "node ./scripts/deploy_switch.mjs --mode=direct:cf+vercel",
    "deploy:vps:vercel": "node ./scripts/deploy_switch.mjs --mode=direct:vps+vercel",
    "deploy:all": "node ./scripts/deploy_switch.mjs --mode=direct:cf+vps+vercel",
    "uploaddist:cf:node": "node ./scripts/uploaddist_cf.mjs",
    "uploaddist:vps:node": "node ./scripts/uploaddist_vps.mjs",
    "uploaddist:vercel:node": "node ./scripts/uploaddist_vercel.mjs",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,astro,css,md}\"",
    "test": "jest && astro build && node ./scripts/run-e2e.mjs",
    "analyze": "node ./scripts/analysis.mjs",
    "selfcheck": "node ./scripts/analysis.mjs",
    "deploy:menu": "node ./scripts/deploy_menu.mjs",
    "upgrade:astro": "node ./scripts/upgrade_astro.mjs",
    "lighthouse": "node ./run-lh.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.3.7",
    "astro-expressive-code": "^0.42.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.5.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^30.4.2",
    "lighthouse": "^13.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  }
}
