# 1) Copy this file to .env.vercel.
# 2) Fill in real Vercel deploy values.
# 3) Keep .env.vercel private (already ignored by .gitignore).

# Vercel Account Settings > Tokens
VERCEL_TOKEN=

# Recommended for non-interactive deploys.
# You can get these after running `vercel link`, or from .vercel/project.json.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
