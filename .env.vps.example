# 1) Copy this file to .env.vps.
# 2) Fill in real VPS deploy values.
# 3) Keep .env.vps private (already ignored by .gitignore).

VPS_HOST=203.0.113.10
VPS_USER=deploy
VPS_PORT=22
VPS_SSH_KEY_PATH=~/.ssh/id_rsa

# Optional. Prefer ssh-agent when possible.
# If your private key is encrypted and you cannot use ssh-agent, set this locally or in CI secrets.
# Do not commit the real passphrase.
VPS_SSH_PASSPHRASE=

VPS_TARGET_DIR=/var/www/astro-site
