# 1) Copy this file to .env.cloudflare (same directory level).
# 2) Fill in real values below.
# 3) Keep .env.cloudflare private (already ignored by .gitignore).
#
# API Token:
# Cloudflare Dashboard > My Profile > API Tokens > Create Token
# Required minimum permission: Account - Cloudflare Pages:Edit
CLOUDFLARE_API_TOKEN=
#
# Account ID:
# Cloudflare Dashboard right sidebar (Account ID)
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Pages project name.
# If this project does not exist, the deploy script creates it and writes the name back to .env.cloudflare.
# If empty, package.json name is used as a fallback.
CLOUDFLARE_PAGES_PROJECT_NAME=

# Public site URL used by Astro output, sitemap, canonical URLs, and structured data.
# Example: https://example.com
PUBLIC_SITE_URL=
